# ================================
# LENDCORE - Configuración de Producción
# ================================
# IMPORTANTE: Copiar este archivo a .env y completar con valores reales
# NO subir .env a Git - está en .gitignore

# ================================
# BASE DE DATOS
# ================================
# PostgreSQL connection string
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd?sslmode=require
DATABASE_URL="postgresql://usuario:contraseña@host:5432/lendcore_production?sslmode=require"

# ================================
# AUTENTICACIÓN (NextAuth v5)
# ================================
# Secret para JWT - Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="CAMBIAR_POR_SECRET_GENERADO"

# URL base de la aplicación
NEXTAUTH_URL="https://tu-dominio.com"

# ================================
# ENCRIPTACIÓN DE DATOS SENSIBLES
# ================================
# Clave AES-256-GCM para encriptar DNI, teléfonos, direcciones
# Generar con: openssl rand -base64 32
# CRÍTICO: Guardar en vault seguro (1Password/LastPass)
ENCRYPTION_KEY="CAMBIAR_POR_KEY_GENERADA"

# ================================
# EMAIL (SMTP)
# ================================
# Configuración para envío de emails (notificaciones, alertas)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="notificaciones@tu-dominio.com"
SMTP_PASSWORD="contraseña_aplicación_gmail"
SMTP_FROM="LendCore <noreply@tu-dominio.com>"

# ================================
# SEGURIDAD
# ================================
# Email para recibir alertas de seguridad
SECURITY_ALERT_EMAIL="admin@tu-dominio.com"

# Habilitar envío de emails de alerta (true/false)
SECURITY_ALERT_ENABLED="true"

# ================================
# ENTORNO
# ================================
NODE_ENV="production"

# Puerto de la aplicación (default: 3001)
PORT="3001"

# ================================
# OPCIONALES (AVANZADO)
# ================================
# Redis para rate limiting (opcional - por defecto usa memoria)
# REDIS_ENABLED="true"
# REDIS_URL="redis://usuario:contraseña@host:6379"

# Cloudflare (opcional - para WAF y CDN)
# CLOUDFLARE_ZONE_ID=""
# CLOUDFLARE_API_TOKEN=""

# ================================
# NOTAS DE SEGURIDAD
# ================================
# 1. NUNCA subir este archivo con valores reales a Git
# 2. Rotar ENCRYPTION_KEY trimestralmente
# 3. Usar contraseñas de aplicación para SMTP (no contraseña personal)
# 4. DATABASE_URL debe usar sslmode=require en producción
# 5. Hacer backup de ENCRYPTION_KEY en ubicación segura separada
